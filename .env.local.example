# Diva Flowers — environment variables
# Copy to .env.local and fill in real values when wiring v2 services.

# Resend / Postmark (Plan 4)
RESEND_API_KEY=

# Stripe (test mode)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
# In dev, this comes from `stripe listen --forward-to localhost:3000/api/stripe/webhook`.
# In prod, from Stripe Dashboard → Developers → Webhooks → endpoint signing secret.
STRIPE_WEBHOOK_SECRET=whsec_...

# Analytics — Google Tag Manager + GA4 (Plan: 2026-05-04 analytics-conversion-tracking)
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX
NEXT_PUBLIC_CLARITY_PROJECT_ID=

# GA4 Measurement Protocol (server-side purchase — wired in Phase 2 with Stripe)
GA4_MEASUREMENT_ID=G-XXXXXXX
GA4_API_SECRET=

# Sanity / Payload (post-v1 CMS swap)
SANITY_PROJECT_ID=
SANITY_DATASET=

ANTHROPIC_API_KEY=sk-ant-...

