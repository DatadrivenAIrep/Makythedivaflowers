# Diva Flowers — environment variables
# Copy to .env.local and fill in real values when wiring v2 services.

# Resend — order notifications to the shop owner
# Get RESEND_API_KEY from https://resend.com/api-keys
# `_FROM` must use a verified domain (https://resend.com/domains).
# `_TO` is the inbox that receives the new-order alert with all delivery details.
RESEND_API_KEY=re_...
ORDER_NOTIFICATIONS_TO=orders@example.com
ORDER_NOTIFICATIONS_FROM=orders@example.com

# Stripe (test mode)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
# In dev, this comes from `stripe listen --forward-to localhost:3000/api/stripe/webhook`.
# In prod, from Stripe Dashboard → Developers → Webhooks → endpoint signing secret.
STRIPE_WEBHOOK_SECRET=whsec_...

# Analytics — Google Tag Manager + GA4 (Plan: 2026-05-04 analytics-conversion-tracking)
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX
NEXT_PUBLIC_CLARITY_PROJECT_ID=

# GA4 Measurement Protocol (server-side purchase — wired in Phase 2 with Stripe)
GA4_MEASUREMENT_ID=G-XXXXXXX
GA4_API_SECRET=

# Sanity / Payload (post-v1 CMS swap)
SANITY_PROJECT_ID=
SANITY_DATASET=

ANTHROPIC_API_KEY=sk-ant-...

# Bearer token used by the in-shop print agent (tools/print-agent) to fetch
# print jobs from /api/print/queue. Generate with: openssl rand -base64 32
# The same value must be set in tools/print-agent/.env on the shop computer.
PRINT_AGENT_TOKEN=
